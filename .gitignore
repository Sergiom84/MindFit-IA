# Logs
logs
*.log
logs.txt
backend/logs.txt
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment variables
.env
.env.local
.env.development
.env.production
backend/.env
backend/.env.local

# Render CLI credentials (NEVER commit)
.render/
**/.render/

# Database backups (contienen datos personales reales - NEVER commit)
_supabase_backup_*/
*.dump

# Claude Code settings with credentials (NEVER commit)
.claude/mcp_settings.json
.claude/settings.local.json

# MCP Configuration (contains access tokens)
.mcp.json

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
# Hooks corregidos y funcionales

# Backups de migración con secretos del proyecto viejo
*.bak-old-project

# Generated exercise media mapping artifacts
backend/scripts/.cache/
backend/scripts/_out/

# Codex CLI artifacts
.codex/

# Android signing (NEVER commit — llaves de subida a Google Play)
android/keystore.properties
*.jks
*.keystore

# Artefactos de build de la app (aab/apk) y capturas
builds/

# QA local DB dumps (catálogo, regenerable con scripts/setup-local-db.sh)
scripts/.local-db/

# Playwright storage state (contiene authToken de sesión — NEVER commit)
output/qa-e2e/storageState.json

# REPO-001: artefactos de QA/build regenerables — nunca versionar.
# Carpetas de salida completas (capturas, dumps, datasets, arneses generados).
output/
backend/output/
# Reportes y resultados de Playwright (regenerables en cada corrida).
playwright-report/
test-results/
# Patrones específicos conservados por claridad (cubiertos por lo anterior):
#   output/**/*.png (capturas E2E, ~178 MiB)
#   backend/output/catalog-audit/exercisedb_numeric.json (dataset ExerciseDB, ~15 MiB)
#   output/qa-e2e/storageState.json (authToken de sesión — ver bloque de arriba)

# DEP-001: SBOM generados en CI (artefactos, no versionar)
sbom-*.json
_sbom_test.json

# OPS-002: keystore inyectado en CI (nunca versionar)
android/app/*.keystore
android/app/release.keystore
