{
  "name": "entrena-con-ia",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "npm --prefix backend run dev",
    "dev:backend:debug": "npm --prefix backend run debug",
    "dev:all": "concurrently -n FRONT,API -c green,cyan \"npm run dev\" \"npm run dev:backend\"",
    "dev:all:debug": "concurrently -n FRONT,API -c green,cyan \"npm run dev\" \"npm run dev:backend:debug\"",
    "dev:sync": "node scripts/check-ports.js && npm run dev",
    "dev:auto": "scripts\\dev-auto.bat",
    "dev:auto:cross": "node scripts/check-ports.js && concurrently -n FRONT,API -c green,cyan \"npm run dev\" \"npm run dev:backend\"",
    "install:all": "npm install && npm --prefix backend install",
    "check-ports": "node scripts/check-ports.js",
    "db:local:setup": "bash scripts/setup-local-db.sh",
    "db:local:backend": "DATABASE_URL=postgresql://$USER@localhost:5432/entrenaconia_local npm run dev:backend",
    "monitor": "node scripts/health-monitor.js",
    "sync-dev": "scripts/sync-dev.bat",
    "lint": "eslint --config .eslint.config.mjs .",
    "build": "vite build",
    "perf:budget": "node scripts/check-bundle-budget.mjs",
    "test:a11y": "playwright test --project=a11y --reporter=list",
    "test:audit-ui": "playwright test --project=audit-ui --reporter=list",
    "test": "npm --prefix backend run test:unit",
    "test:backend": "npm --prefix backend run test:unit",
    "test:backend:integration": "npm --prefix backend run test:integration",
    "qa:arch002:db": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/arch002-test-db.ps1 reset",
    "qa:arch002:db:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/arch002-test-db.ps1 stop",
    "migrate:nutrition-review": "npm --prefix backend run migrate:nutrition-review",
    "migrate:nutrition-adjustments": "npm --prefix backend run migrate:nutrition-adjustments",
    "postinstall": "node -e \"try { require('child_process').execSync('husky install', {stdio:'ignore'}) } catch (e) {}\"",
    "pre-commit": "lint-staged",
    "preview": "vite preview",
    "dev:helper": "scripts\\dev-helper.bat",
    "ports:fix": "scripts\\dev-helper.bat",
    "render:auth": "bash scripts/render-auth.sh",
    "render:auth:win": "scripts\\render-auth.bat",
    "render:apikey": "bash scripts/render-set-apikey.sh",
    "render:install:win": "scripts\\install-render-windows.bat",
    "render:wsl": "scripts\\render-from-windows.bat",
    "render:whoami": "scripts\\render-whoami.bat",
    "render:services": "scripts\\render-services.bat",
    "render:logs": "bash scripts/render-logs.sh",
    "render:logs:win": "scripts\\render-logs.bat",
    "render:tail": "render logs --tail",
    "render:deploy": "render services",
    "build:mobile": "vite build --mode mobile",
    "mobile:sync": "npm run build:mobile && npx cap sync",
    "ios:sync": "npm run build:mobile && npx cap sync ios",
    "ios:open": "npx cap open ios",
    "android:sync": "npm run build:mobile && npx cap sync android"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.67.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@playwright/test": "^1.56.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.2",
    "framer-motion": "^12.23.12",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.510.0",
    "multer": "^2.0.2",
    "node-fetch": "^3.3.2",
    "pdf-parse": "^1.1.1",
    "pg": "^8.16.3",
    "postcss": "^8.5.6",
    "postgres": "^3.4.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.56.3",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.6.1",
    "recharts": "^2.15.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^3.4.17",
    "vite": "^6.3.5",
    "web-vitals": "^4.2.4",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@capacitor/assets": "^3.0.5",
    "@eslint/js": "^9.33.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "concurrently": "^10.0.3",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "glob": "^11.0.3",
    "globals": "^16.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "terser": "^5.44.0",
    "vite-plugin-inspect": "^11.3.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --config .eslint.config.mjs --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "backend/**/*.js": [
      "node -c"
    ]
  }
}
