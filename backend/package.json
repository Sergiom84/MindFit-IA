{
  "name": "entrena-con-ia-backend",
  "version": "1.0.0",
  "description": "Backend para la aplicación MindFit",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon --watch . server.js",
    "test": "node scripts/run-tests.mjs unit",
    "test:unit": "node scripts/run-tests.mjs unit",
    "test:integration": "node scripts/run-tests.mjs integration",
    "test:all": "node --test tests/**/*.test.js",
    "migrate:status": "node scripts/migrate.mjs status",
    "migrate:check": "node scripts/migrate.mjs status --check",
    "migrate:baseline": "node scripts/migrate.mjs baseline",
    "migrate:up": "node scripts/migrate.mjs up",
    "migrate:reconcile": "node scripts/migrate.mjs reconcile",
    "migrate:new": "node scripts/migrate.mjs new",
    "migrate:nutrition-review": "echo \"[DEPRECADO DB-001] runner ad-hoc fuera del ledger; usa migrate.mjs para DDL nuevo.\" && node scripts/run-nutrition-review-migration.js",
    "migrate:nutrition-adjustments": "echo \"[DEPRECADO DB-001] runner ad-hoc fuera del ledger; usa migrate.mjs para DDL nuevo.\" && node scripts/run-nutrition-adjustments-migration.js",
    "migrate:nutrition-recipes": "echo \"[DEPRECADO DB-001] runner ad-hoc fuera del ledger; usa migrate.mjs para DDL nuevo.\" && node scripts/run-nutrition-recipes-migration.js",
    "backfill:nutrition-food-semantics": "node scripts/backfill-food-semantics.mjs",
    "baseline:nutrition-menu-quality": "node scripts/generate-menu-quality-baseline.mjs",
    "qa:nutrition-menu-hard-rules": "node scripts/run-menu-hard-rules-qa.mjs",
    "import:nutrition-recipe-examples": "node scripts/import-recipe-examples-from-excel.js",
    "normalize:nutrition-recipe-names": "node scripts/normalize-recipe-names.js",
    "curate:nutrition-recipe-names": "node scripts/curate-recipe-names.js",
    "postinstall": "echo \"(backend) postinstall ok\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.7",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.6.0",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.0.2",
    "node-cron": "^4.6.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.104.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "exceljs": "^4.4.0",
    "nodemon": "^3.1.14"
  },
  "keywords": [
    "fitness",
    "ai",
    "training",
    "backend"
  ],
  "author": "MindFit",
  "license": "MIT"
}
