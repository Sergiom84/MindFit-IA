# PLANTILLA SEGURA: SIN CREDENCIALES
# ===========================================
# VARIABLES DE ENTORNO - TEMPLATE
# ===========================================
# 1. Copia este archivo como .env.
# 2. Completa los valores vacios solo en tu archivo local.
# 3. Nunca incluyas credenciales reales en este template ni en Git.

# ===========================================
# SUPABASE DATABASE CONFIGURATION
# ===========================================
# Usa una URI local o del entorno correspondiente. No pongas credenciales aqui.
DATABASE_URL=

# Configuracion especifica de BD
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mindfit
DB_USER=postgres
DB_PASSWORD=
DB_SEARCH_PATH=app,public

# Supabase URLs y keys
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=

# Variables publicas si se necesitan en frontend
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ===========================================
# OPENAI API KEYS
# ===========================================
# Opcion unificada recomendada
OPENAI_API_KEY=

# Keys especificas por modulo si se requiere aislamiento de costes
OPENAI_API_KEY_HOME_TRAINING=
OPENAI_API_KEY_CORRECTION_VIDEO=
OPENAI_API_KEY_CORRECTION_PHOTO=
OPENAI_API_KEY_METHODOLOGIE=
OPENAI_API_KEY_METHODOLOGIE_MANUAL=

# ===========================================
# CONFIGURACION DEL SERVIDOR
# ===========================================
PORT=3010
NODE_ENV=development
JWT_SECRET=

# ===========================================
# CONFIGURACION DE ARCHIVOS
# ===========================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
OPENAI_VISION_MODEL=gpt-4o

# ===========================================
# CONFIGURACION OPCIONAL
# ===========================================
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
FRONTEND_URL=http://localhost:5173
ADMIN_TOKEN=

# ===========================================
# CROSSFIT V2 - ROLLOUT SEGURO (DEFAULT OFF)
# ===========================================
CROSSFIT_V2_GENERATION=false
CROSSFIT_V2_RESULTS=false
CROSSFIT_EMITS_TRAINING_LOAD=false
CROSSFIT_NUTRITION_LOAD=false
CROSSFIT_V2_QA_USERS=
