# ===========================================
# 📋 VARIABLES DE ENTORNO - TEMPLATE
# ===========================================
# 🚨 IMPORTANTE:
# 1. Copia este archivo como .env
# 2. Reemplaza TODOS los valores placeholder por valores reales
# 3. NUNCA commitees el archivo .env al repositorio
# ===========================================

# ===========================================
# 🗄️ SUPABASE DATABASE CONFIGURATION
# ===========================================
# Para desarrollo local (pooler connection) - RECOMENDADO
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:REDACTED_ROTATE_ME@aws-1-eu-north-1.pooler.supabase.com:6543/postgres

# Configuración específica de BD
DB_HOST=db.YOUR_PROJECT_REF.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=YOUR_DB_PASSWORD
DB_SEARCH_PATH=app,public

# Supabase URLs y keys
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_PROJECT_REF=YOUR_PROJECT_REF

# Next.js public variables (si se necesitan en frontend)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ===========================================
# 🤖 OPENAI API KEYS
# ===========================================
# OPCIÓN 1: API Key unificada (recomendado para simplicidad)
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY

# OPCIÓN 2: API Keys específicas por módulo (para mejor control de costos)
OPENAI_API_KEY_HOME_TRAINING=sk-proj-YOUR_HOME_TRAINING_KEY
OPENAI_API_KEY_CORRECTION_VIDEO=sk-proj-YOUR_VIDEO_CORRECTION_KEY
OPENAI_API_KEY_CORRECTION_PHOTO=sk-proj-YOUR_PHOTO_CORRECTION_KEY
OPENAI_API_KEY_METHODOLOGIE=sk-proj-YOUR_METHODOLOGIE_KEY
OPENAI_API_KEY_METHODOLOGIE_MANUAL=sk-proj-YOUR_METHODOLOGIE_MANUAL_KEY

# ===========================================
# 🔧 CONFIGURACIÓN DEL SERVIDOR
# ===========================================
# Puerto del servidor backend
PORT=3002

# Entorno de ejecución
NODE_ENV=development

# JWT Secret - 🚨 GENERA UNO ÚNICO Y SEGURO
JWT_SECRET=your_super_secure_jwt_secret_minimum_32_characters

# ===========================================
# 📁 CONFIGURACIÓN DE ARCHIVOS
# ===========================================
UPLOAD_DIR=uploads
MAX_FILE_SIZE=26214400
OPENAI_VISION_MODEL=gpt-4o-mini

# ===========================================
# 🎵 CONFIGURACIÓN OPCIONAL (SI SE USA)
# ===========================================
# Spotify API (si se implementa integración musical)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
FRONTEND_URL=http://localhost:5173

# Analytics/Admin (si se usa)
ADMIN_TOKEN=your_admin_token
